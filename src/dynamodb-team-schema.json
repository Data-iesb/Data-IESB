{
  "TableName": "DataIESB-Team",
  "AttributeDefinitions": [
    {
      "AttributeName": "id",
      "AttributeType": "S"
    }
  ],
  "KeySchema": [
    {
      "AttributeName": "id",
      "KeyType": "HASH"
    }
  ],
  "BillingMode": "PAY_PER_REQUEST",
  "TableDescription": "Team members data for Data IESB project",
  "ItemStructure": {
    "id": {
      "type": "String",
      "description": "Unique identifier for team member",
      "required": true,
      "example": "1"
    },
    "email": {
      "type": "String",
      "description": "Team member's email address",
      "required": true,
      "example": "sergio.cortes@iesb.edu.br"
    },
    "name": {
      "type": "String",
      "description": "Full name of team member",
      "required": true,
      "example": "Prof. Sérgio da Costa Côrtes"
    },
    "role": {
      "type": "String",
      "description": "Job title/role of team member",
      "required": true,
      "example": "Coordenador Geral"
    },
    "category": {
      "type": "String",
      "description": "Team category (Coordenação or Technical Team)",
      "required": true,
      "enum": ["Coordenação", "Technical Team"],
      "example": "Coordenação"
    },
    "linkedin": {
      "type": "String",
      "description": "LinkedIn profile URL (optional, for Technical Team)",
      "required": false,
      "example": "https://linkedin.com/in/roberto-diniz",
      "note": "Can be null if member doesn't have LinkedIn. Only for Technical Team members."
    },
    "escavador": {
      "type": "String", 
      "description": "Escavador profile URL (optional, for Coordenação)",
      "required": false,
      "example": "https://www.escavador.com/sobre/sergio-cortes",
      "note": "Can be null if member doesn't have Escavador profile. Only for Coordenação members."
    },
    "active": {
      "type": "Boolean",
      "description": "Whether team member is currently active",
      "required": true,
      "default": true,
      "example": true
    }
  },
  "SampleData": [
    {
      "id": "1",
      "email": "sergio.cortes@iesb.edu.br",
      "name": "Prof. Sérgio da Costa Côrtes",
      "role": "Coordenador Geral",
      "category": "Coordenação",
      "linkedin": null,
      "escavador": "https://www.escavador.com/sobre/sergio-cortes",
      "active": true
    },
    {
      "id": "2",
      "email": "simone.a.assis@iesb.edu.br",
      "name": "Profa. Simone de Araújo Góes Assis",
      "role": "Coordenadora Acadêmica",
      "category": "Coordenação",
      "linkedin": null,
      "escavador": null,
      "active": true
    },
    {
      "id": "4",
      "email": "roberto.diniz@iesb.edu.br",
      "name": "Roberto Moreira Diniz",
      "role": "Especialista DevOps",
      "category": "Technical Team",
      "linkedin": "https://linkedin.com/in/roberto-diniz",
      "escavador": null,
      "active": true
    }
  ],
  "Notes": [
    "LinkedIn field is optional and should be null (not empty string) when not available",
    "Category field should only contain 'Coordenação' or 'Technical Team'",
    "Role field for former 'Cientista de Dados' should be updated to 'Analista de Dados e IA'",
    "All team members except coordination should be categorized as 'Technical Team'"
  ]
}
